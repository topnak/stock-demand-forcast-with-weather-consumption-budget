# ================================================
# Southern Scoops — Web App Configuration
# ================================================
# Copy this file to .env and fill in your values.
# These values are injected at build time or loaded
# via a config endpoint for Azure Static Web Apps.
# ================================================

# Azure Maps (used for interactive store map)
AZURE_MAPS_KEY=

# Azure OpenAI (used for chat assistant)
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Data paths (relative or absolute URL)
INPUT_BASE=input
OUTPUT_BASE=output
